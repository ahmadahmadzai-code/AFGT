// AFG Tech CMS — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  NEW
  CONTACTED
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(EDITOR)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  posts         Post[]
  media         Media[]
}

model Project {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  industry      String
  year          Int
  summary       String
  body          String    @db.Text
  coverImage    String
  gallery       String[]  @default([])
  technologies  String[]  @default([])
  featured      Boolean   @default(false)
  published     Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  authorId      String
  author        User      @relation(fields: [authorId], references: [id])

  @@index([published, publishedAt])
  @@index([industry])
}

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  icon        String
  shortDesc   String
  body        String   @db.Text
  features    String[] @default([])
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, order])
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String   @db.Text
  author    String
  role      String
  company   String
  avatar    String?
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featured, order])
}

model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String
  body        String     @db.Text
  coverImage  String
  tags        String[]   @default([])
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  authorId    String
  author      User       @relation(fields: [authorId], references: [id])

  @@index([status, publishedAt])
}

model Industry {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  icon        String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model ContactSubmission {
  id        String           @id @default(cuid())
  name      String
  email     String
  company   String?
  budget    String?
  message   String           @db.Text
  status    SubmissionStatus @default(NEW)
  notes     String?          @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status, createdAt])
}

model Media {
  id          String   @id @default(cuid())
  url         String
  key         String   @unique
  filename    String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  alt         String?
  uploadedBy  String?
  user        User?    @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model SiteSettings {
  id         String   @id @default("singleton")
  siteName   String   @default("AFG Tech")
  tagline    String   @default("Software that drives outcomes.")
  email      String   @default("hello@afgtech.com")
  phone      String   @default("+1 (817) 555-0188")
  address    String   @default("Grapevine, TX")
  socials    Json     @default("{}")
  seoImage   String?
  updatedAt  DateTime @updatedAt
}
